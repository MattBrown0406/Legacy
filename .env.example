# Legacy — Supabase (NEW, standalone project; separate from Sober Helpline)
# Copy this file to .env and paste your project's values. .env is gitignored.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Google Calendar OAuth — the OAuth *client ID* is public (safe in the client).
# The client *secret* goes in Supabase secrets only, never here.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=YOUR-GOOGLE-OAUTH-CLIENT-ID.apps.googleusercontent.com
