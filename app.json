{
  "expo": {
    "name": "Legacy",
    "slug": "legacy",
    "version": "1.0.0",
    "orientation": "default",
    "scheme": "legacy",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FCF9F2"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.freedominterventions.legacy",
      "buildNumber": "2",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.freedominterventions.legacy"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FCF9F2",
          "resizeMode": "contain"
        }
      ],
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "color": "#142A47",
          "sounds": []
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "bd4894d6-5010-4203-94fa-caa33d756425"
      }
    }
  }
}
